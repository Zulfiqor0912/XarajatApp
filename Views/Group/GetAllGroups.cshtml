@model List<XarajatApp.ViewModels.GetAllGroupsViewModel>

@{
    ViewData["Title"] = "Barcha guruhlar";
}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">📋 Barcha guruhlar</h2>
            <p class="text-muted mb-0">
                Mavjud guruhlardan birini tanlab qo'shiling.
            </p>
        </div>

        <a asp-action="Menu"
           asp-controller="Group"
           class="btn btn-outline-secondary">
            ⬅ Orqaga
        </a>
    </div>

    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-header bg-white border-0 py-3">
            <h5 class="mb-0 fw-semibold">
                Guruhlar ro'yxati
            </h5>
        </div>

        <div class="card-body p-0">

            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">

                    <table class="table align-middle mb-0">

                        <thead class="table-light">
                            <tr>
                                <th style="width:70px;">#</th>
                                <th>Guruh nomi</th>
                                <th class="text-center" style="width:180px;">
                                    Amal
                                </th>
                            </tr>
                        </thead>

                        <tbody>

                            @{
                                int number = 1;
                            }

                            @foreach (var group in Model)
                            {
                                <tr>

                                    <td>
                                        <span class="badge bg-secondary fs-6">
                                            @number
                                        </span>
                                    </td>

                                    <td class="fw-semibold">
                                        👥 @group.Name
                                    </td>

                                    <td class="text-center">

                                        <a asp-action="JoinGroup"
                                           asp-route-groupName="@group.Name"
                                           class="btn btn-success btn-sm px-4">
                                            Qo'shilish
                                        </a>

                                    </td>

                                </tr>

                                number++;
                            }

                        </tbody>

                    </table>

                </div>
            }
            else
            {
                <div class="text-center py-5">

                    <div style="font-size:60px;">
                        📂
                    </div>

                    <h5 class="mt-3">
                        Guruhlar topilmadi
                    </h5>

                    <p class="text-muted">
                        Hozircha tizimda hech qanday guruh mavjud emas.
                    </p>

                </div>
            }

        </div>

    </div>

</div>