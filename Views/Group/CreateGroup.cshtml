@model XarajatApp.ViewModels.CreateGroupViewModel

@{
    ViewData["Title"] = "Yangi guruh yaratish";
}

<div class="container mt-5">
    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">➕ Yangi guruh yaratish</h3>
                </div>

                <div class="card-body">

                    <form asp-action="CreateGroup" method="post">

                        <div class="mb-3">
                            <label asp-for="GroupName" class="form-label"></label>
                            <input asp-for="GroupName" class="form-control" placeholder="Guruh nomini kiriting" />
                            <span asp-validation-for="GroupName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="GroupPassword" class="form-label"></label>
                            <input asp-for="GroupPassword"
                                   type="password"
                                   class="form-control"
                                   placeholder="Guruh parolini kiriting" />
                            <span asp-validation-for="GroupPassword" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">

                            <a asp-controller="Group"
                               asp-action="Menu"
                               class="btn btn-secondary">
                                ⬅️ Orqaga
                            </a>

                            <button type="submit" class="btn btn-success">
                                💾 Guruh yaratish
                            </button>

                        </div>

                    </form>

                </div>
            </div>

        </div>

    </div>
</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}