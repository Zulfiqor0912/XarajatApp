@model List<GroupMemberViewModel>

@{
    ViewData["Title"] = "Guruh a'zolari";
}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-1">👥 Guruh a'zolari</h2>
            <p class="text-muted mb-0">
                Ushbu guruhdagi barcha ishtirokchilar.
            </p>
        </div>

        <a asp-controller="Expenditure"
           asp-action="ExpenditureMenu"
           class="btn btn-outline-secondary">
            ⬅ Orqaga
        </a>

    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">

            @{
                int index = 1;
            }

            @foreach (var member in Model)
            {
                <div class="col-lg-4 col-md-6">

                    <div class="member-card h-100">

                        <div class="member-avatar">
                            @(member.Username.Substring(0, 1).ToUpper())
                        </div>

                        <div class="member-info">

                            <span class="badge bg-primary mb-2">
                                #@index
                            </span>

                            <h5 class="mb-1 fw-bold">
                                @member.Username
                            </h5>

                            <p class="text-muted mb-0">
                                Guruh ishtirokchisi
                            </p>

                        </div>

                    </div>

                </div>

                index++;
            }

        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4">

            <div class="card-body text-center py-5">

                <div style="font-size:60px;">
                    👤
                </div>

                <h4 class="mt-3">
                    A'zolar topilmadi
                </h4>

                <p class="text-muted">
                    Ushbu guruhda hozircha hech kim mavjud emas.
                </p>

            </div>

        </div>
    }

</div>