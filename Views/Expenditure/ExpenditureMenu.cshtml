@model ExpenditureMenuViewModel

@{
    ViewData["Title"] = "Guruh menyusi";
}

<div class="container py-5">

    <div class="text-center mb-5">
        <h2 class="fw-bold">💰 Guruh menyusi</h2>
        <p class="text-muted">
            Kerakli amalni tanlang
        </p>
    </div>

    <div class="row g-4">

        <div class="col-lg-6">
            <a asp-controller="Expenditure"
               asp-action="CreateExpenditure"
               class="menu-card text-decoration-none">

                <div class="menu-icon bg-primary">
                    💸
                </div>

                <div>
                    <h4>Xarajat qilish</h4>
                    <p>Yangi xarajat qo'shing.</p>
                </div>

            </a>
        </div>

        <div class="col-lg-6">
            <a asp-controller="Expenditure"
               asp-action="Calculate"
               class="menu-card text-decoration-none">

                <div class="menu-icon bg-success">
                    🧮
                </div>

                <div>
                    <h4>Hisoblash</h4>
                    <p>Kim qancha oladi yoki to'laydi.</p>
                </div>

            </a>
        </div>

        <div class="col-lg-6">
            <a asp-controller="Expenditure"
               asp-action="ExpenditureHistory"
               class="menu-card text-decoration-none">

                <div class="menu-icon bg-warning">
                    📜
                </div>

                <div>
                    <h4>Xarajatlar tarixi</h4>
                    <p>Barcha xarajatlarni ko'ring.</p>
                </div>

            </a>
        </div>

        <div class="col-lg-6">
            <a asp-controller="Expenditure"
               asp-action="ShowAllGroupMembers"
               asp-route-groupname="@Model.Groupname"
               class="menu-card text-decoration-none">

                <div class="menu-icon bg-info">
                    👥
                </div>

                <div>
                    <h4>Guruh a'zolari</h4>
                    <p>Ishtirokchilar ro'yxati.</p>
                </div>

            </a>
        </div>

    </div>

    <div class="text-center mt-5">
        <a asp-controller="Group"
           asp-action="GetAllGroups"
           class="btn btn-outline-secondary btn-lg px-4">
            ⬅ Guruhlar ro'yxati
        </a>
    </div>

</div>