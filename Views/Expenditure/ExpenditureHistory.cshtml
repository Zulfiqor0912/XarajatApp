@model List<XarajatApp.ViewModels.GetAllExpendituresViewModel>

@{
    ViewData["Title"] = "Harajatlar tarixi";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Harajatlar tarixi</h3>
        </div>

        <div class="card-body">

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Error"]
                </div>
            }

            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-warning text-center">
                    Hozircha hech qanday harajat mavjud emas.
                </div>
            }
            else
            {
                <table class="table table-bordered table-hover align-middle">

                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Username</th>
                            <th>To'liq ism</th>
                            <th>Summa</th>
                            <th>Tavsif</th>
                            <th>Sana</th>
                        </tr>
                    </thead>

                    <tbody>

                        @{
                            int i = 1;
                        }

                        @foreach (var item in Model.OrderByDescending(x => x.CreatedDate))
                        {
                            <tr>
                                <td>@i</td>
                                <td>@item.Username</td>
                                <td>@item.Fullname</td>
                                <td class="text-success fw-bold">
                                    @item.Amount.ToString("N0") so'm
                                </td>
                                <td>@item.Description</td>
                                <td>
                                    @item.CreatedDate.ToString("dd.MM.yyyy HH:mm")
                                </td>
                            </tr>

                            i++;
                        }

                    </tbody>

                </table>

                <div class="mt-3 text-end">
                    <h5>
                        Jami harajat:
                        <span class="text-danger">
                            @Model.Sum(x => x.Amount).ToString("N0") so'm
                        </span>
                    </h5>
                </div>
            }

        </div>

    </div>

</div>