@model XarajatApp.ViewModels.CreateExpenditureViewModel

@{
    ViewData["Title"] = "Harajat qo'shish";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0 text-center">Harajat qo'shish</h3>
                </div>

                <div class="card-body">

                    <form asp-action="CreateExpenditure" method="post">

                        <div class="mb-3">
                            <label asp-for="Username" class="form-label"></label>
                            <input asp-for="Username" class="form-control" placeholder="Username kiriting" />
                            <span asp-validation-for="Username" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Fullname" class="form-label"></label>
                            <input asp-for="Fullname" class="form-control" placeholder="To'liq ism kiriting" />
                            <span asp-validation-for="Fullname" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Amount" class="form-label"></label>
                            <input asp-for="Amount" type="number" step="0.01" class="form-control" placeholder="Harajat summasi" />
                            <span asp-validation-for="Amount" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" rows="4" class="form-control" placeholder="Harajat tavsifi"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-success">
                                Saqlash
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}